# TCP MQTT brokers (MQTT v3.1.1, plain TCP).
# Add as many indexed groups as needed; scanning stops at the first missing ADDR.
MQTT_BROKER_0_ADDR=192.168.1.x:1883
MQTT_BROKER_0_USER=
MQTT_BROKER_0_PASS=

# MQTT_BROKER_1_ADDR=
# MQTT_BROKER_1_USER=
# MQTT_BROKER_1_PASS=

# WS MQTT brokers (MQTT v5 over WSS, JWT auth).
# Add as many indexed groups as needed; scanning stops at the first missing URL.
WS_BROKER_0_URL=wss://mqtt-a.waev.app:443
WS_BROKER_1_URL=wss://mqtt-b.waev.app:443

# Node keypairs — add as many indexed groups as needed (0, 1, 2, …).
# Scanning stops at the first index where both PUBLIC and PRIVATE are unset.
#
# MESHCORE_KEY_N_PUBLIC:  32-byte Ed25519 public key in hex (64 hex chars).
# MESHCORE_KEY_N_PRIVATE: 64-byte expanded private key in hex (128 hex chars).
#                         SHA-512(seed) with clamping — the "expanded" key format.
# MESHCORE_KEY_N_EMAIL:   optional owner email embedded in the JWT.
MESHCORE_KEY_0_PUBLIC=
MESHCORE_KEY_0_PRIVATE=
MESHCORE_KEY_0_EMAIL=

# MESHCORE_KEY_1_PUBLIC=
# MESHCORE_KEY_1_PRIVATE=
# MESHCORE_KEY_1_EMAIL=

# JWT token lifetime in seconds (default: 3300 = 55 min).
# Waev.app rejects tokens with exp > 3600s from iat — keep this at or below 3600.
TOKEN_LIFETIME=3300

# "client" claim in the JWT. Change if the broker expects a specific client string.
TOKEN_CLIENT=hackru-mqtt-proxy/1.0

# Local listener address (default :1883)
LOCAL_LISTEN=:1883

# Credentials required from devices connecting to the local broker.
# If unset, any credentials (or none) are accepted.
LOCAL_MQTT_USER=
LOCAL_MQTT_PASS=

# Log verbosity: debug | info | warn | error
# Use debug to see every forwarded message and JWT generation events.
LOG_LEVEL=info
